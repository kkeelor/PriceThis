GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-3.1-flash-lite

# Progressive scan pipeline (on by default; set false for legacy single-shot)
SCAN_PIPELINE=true
SCAN_ID_FAIL_FLOOR=50
SCAN_SEARCH_THRESHOLD=70
SCAN_CATEGORY_SEARCH_THRESHOLD=75
SCAN_AMBIGUITY_MARGIN=15
SCAN_CATEGORY_STRICT_CATEGORIES=watches,art,cars,collectibles,real_estate

PORT=3000
MARKET_DATA_ENABLED=true
