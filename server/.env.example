ANTHROPIC_API_KEY=sk-ant-your-key-here

# Default model when no preset is requested (Haiku = fast + cheap)
CLAUDE_MODEL=claude-haiku-4-5

# Named presets — request with body.model or X-Claude-Model header
CLAUDE_MODEL_SONNET=claude-sonnet-4-6
CLAUDE_MODEL_OPUS=claude-opus-4-6
CLAUDE_MODEL_HAIKU=claude-haiku-4-5
CLAUDE_MODEL_FAST=claude-haiku-4-5
CLAUDE_MODEL_QUALITY=claude-opus-4-6

# Web search for price grounding (on by default; set false to disable)
CLAUDE_WEB_SEARCH=true
WEB_SEARCH_MAX_USES=1

# Progressive scan pipeline (on by default; set false for legacy single-shot)
SCAN_PIPELINE=true
SCAN_ID_FAIL_FLOOR=50
SCAN_SEARCH_THRESHOLD=70
SCAN_CATEGORY_SEARCH_THRESHOLD=75
SCAN_AMBIGUITY_MARGIN=15
SCAN_CATEGORY_STRICT_CATEGORIES=watches,art,cars,collectibles,real_estate

PORT=3000
MARKET_DATA_ENABLED=true
