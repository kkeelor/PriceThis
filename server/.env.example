ANTHROPIC_API_KEY=sk-ant-your-key-here

# Default model when no preset is requested
CLAUDE_MODEL=claude-sonnet-4-6

# Named presets — request with body.model or X-Claude-Model header
CLAUDE_MODEL_SONNET=claude-sonnet-4-6
CLAUDE_MODEL_OPUS=claude-opus-4-6
CLAUDE_MODEL_HAIKU=claude-haiku-4-5
CLAUDE_MODEL_FAST=claude-haiku-4-5
CLAUDE_MODEL_QUALITY=claude-opus-4-6

PORT=3000
MARKET_DATA_ENABLED=true
