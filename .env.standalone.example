# Standalone / on-the-go builds (baked into the APK at build time)
#
# Option A — Deployed API (works anywhere with cell/WiFi):
#   API_BASE_URL=https://your-app.vercel.app
#
# Option B — Home WiFi only (Mac must run ./scripts/start-api.sh on same network):
#   API_BASE_URL=http://192.168.1.5:3000
#
# localhost does NOT work on a physical device when unplugged from USB.

API_BASE_URL=https://your-pricethis-api.vercel.app
